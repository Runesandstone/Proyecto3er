<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Proyecto_Parcial3" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->

        <!-- Color de los elementos principales (como los Chips y Checkboxes) -->
        <item name="colorPrimary">@color/verde</item>
        <item name="colorPrimaryVariant">@color/verde_oscuro</item>
        <item name="android:statusBarColor">@color/verde</item> <!-- O el verde oscuro para que contraste -->


    </style>

    <style name="Theme.Proyecto_Parcial3" parent="Base.Theme.Proyecto_Parcial3" />

    <style name="Theme.Proyecto_Parcial3.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.Proyecto_Parcial3.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.Proyecto_Parcial3.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
</resources>